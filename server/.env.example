# Fixed local admin login. On first boot the app seeds the root account `Nana`
# with this password if the auth database does not exist yet.
ADMIN_PASSWORD=12345

# Optional: use a stable JWT secret locally instead of auto-generating one.
# JWT_SECRET=replace-with-a-long-random-string

# Backend port
PORT=8000

# Optional Qdrant settings. Leave enabled to use Qdrant when available;
# the server falls back to local vectra indices automatically if Qdrant is down.
QDRANT_ENABLED=1
QDRANT_URL=http://127.0.0.1:6333
# QDRANT_API_KEY=

# Optional local embedding overrides
# LOCAL_EMBEDDING_MODEL=Xenova/bge-m3
# LOCAL_EMBEDDING_DIM=1024
# LOCAL_EMBEDDING_INDEX_TAG=bge_m3_1024
